@page "/"
@rendermode InteractiveServer

<PageTitle>Inicio - MilitaryComparator</PageTitle>

<div class="hero-section text-center text-white d-flex align-items-center justify-content-center">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-8">
                <div class="container-hero p-4 p-md-5 rounded shadow-lg mx-auto">
                    <h1 class="display-3 fw-bold mb-3">MilitaryComparator</h1>
                    <p class="lead fs-4 mb-4">La herramienta definitiva para la comparación técnica de vehículos
                        blindados de vanguardia.</p>
                    <div class="d-flex justify-content-center gap-3 flex-wrap">
                        <a href="/nations" class="btn btn-outline-light btn-lg px-4 hover-scale">Explorar Naciones</a>
                        <a href="/vehicles" class="btn btn-primary btn-lg px-4 hover-scale">Ver Blindados</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container my-5 overflow-hidden">
    <div class="row g-4 py-5 justify-content-center">
        <div class="col-md-4 text-center">
            <div class="feature-icon bg-dark bg-gradient mb-3 mx-auto">
                <i class="bi bi-globe text-white"></i>
            </div>
            <h3>Base de Datos Global</h3>
            <p>Accede a información detallada sobre los blindados de las principales potencias militares del mundo.</p>
        </div>
        <div class="col-md-4 text-center">
            <div class="feature-icon bg-dark bg-gradient mb-3 mx-auto">
                <i class="bi bi-shield-shaded text-white"></i>
            </div>
            <h3>Categorización Precisa</h3>
            <p>Desde Tanques Principales de Batalla (MBT) hasta vehículos blindados sobre ruedas.</p>
        </div>
        <div class="col-md-4 text-center">
            <div class="feature-icon bg-dark bg-gradient mb-3 mx-auto">
                <i class="bi bi-arrow-left-right text-white"></i>
            </div>
            <h3>Comparador Técnico</h3>
            <p>Compara las especificaciones técnicas para entender las ventajas estratégicas de cada blindado.</p>
        </div>
    </div>

    <div class="text-center mt-5">
        <a href="/comparator" class="btn btn-dark btn-lg px-5 py-3 rounded-pill shadow-lg hover-scale">
            Comenzar Comparación
        </a>
    </div>
</div>

<style>
    .hero-section {
        background: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url('images/hero_bg.jpg');
        background-size: cover;
        background-position: center;
        min-height: 70vh;
        overflow: hidden;
        width: 100%;
    }

    .container-hero {
        background-color: rgba(20, 25, 30, 0.85);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .feature-icon {
        width: 4rem;
        height: 4rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        border-radius: 50%;
    }

    .btn-primary {
        background-color: #3e4e5e;
        border-color: #3e4e5e;
    }

    .btn-primary:hover {
        background-color: #2c3946;
        border-color: #2c3946;
    }

    .hover-scale {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        text-decoration: none !important;
    }

    .hover-scale:hover {
        transform: translateY(-3px) scale(1.02);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
        color: white !important;
    }
</style>
